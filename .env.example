# AfriMarket – Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is ignored by git.

# ─── PostgreSQL (obligatoire) ──────────────────────────────────────────────────
# Format: postgresql://utilisateur:motdepasse@hote:port/nom_base
DATABASE_URL=postgresql://postgres:password@localhost:5432/afrimarket

# ─── EODHD API (pour les vraies données BRVM) ─────────────────────────────────
# Inscription gratuite sur https://eodhd.com (20 appels/jour)
EODHD_API_KEY=

# ─── Frontend (optionnel) ────────────────────────────────────────────────────
# Laisser vide en développement local (Vite proxie /api/* vers localhost:3001).
# En production sur un serveur, mettre l'URL publique de votre API Express.
# VITE_API_BASE_URL=https://api.votreserveur.com
